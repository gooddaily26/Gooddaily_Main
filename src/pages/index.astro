---

<BaseLayout title={SEO.home.title} description={SEO.home.description} ogTitle={SEO.home.ogTitle} ogDescription={SEO.home.ogDescription} image={SEO.home.ogImage}>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(orgJsonLd)} />

  <div class="page-home">
    <!-- ① 히어로 -->
    <section class="home-hero" aria-labelledby="home-hero-title">
      <div class="home-hero-butterflies" aria-hidden="true">
        <span class="home-hero-butterfly home-hero-butterfly--yellow">
          <span class="home-hero-butterfly__body">
            <span class="home-hero-butterfly__frame home-hero-butterfly__frame--closed"></span>
            <span class="home-hero-butterfly__frame home-hero-butterfly__frame--mid"></span>
            <span class="home-hero-butterfly__frame home-hero-butterfly__frame--open"></span>
          </span>
        </span>
        <span class="home-hero-butterfly home-hero-butterfly--white">
          <span class="home-hero-butterfly__body">
            <span class="home-hero-butterfly__frame home-hero-butterfly__frame--closed"></span>
            <span class="home-hero-butterfly__frame home-hero-butterfly__frame--mid"></span>
            <span class="home-hero-butterfly__frame home-hero-butterfly__frame--open"></span>
          </span>
        </span>
      </div>
      <div class="container home-hero__inner">
        <div class="home-hero__content">
          <p class="common-badge home-hero__badge">결제 · 마케팅 · 상품권 · 솔루션</p>
          <h1 id="home-hero-title">함께하는 모든 날을 좋은날로</h1>
          <p class="home-hero__lead">
            {Array.from(heroLeadPrefix).map((char, index) => (
              char === '\n' ? (
                <br class="home-hero__lead-break" aria-hidden="true" />
              ) : (
                <span
                  class:list={[
                    'home-hero__lead-char',
                    { 'home-hero__lead-char--space': char === ' ' },
                    { 'home-hero__lead-char--brand-gap': char === ' ' && index === heroLeadPrefix.length - 1 },
                  ]}
                  style={`--char-delay: ${index * 42}ms`}
                  aria-hidden="true"
                >
                  {char}
                </span>
              )
            ))}
            <span
              class="home-hero__title-gradient"
              style={`--char-delay: ${heroLeadPrefix.length * 42}ms`}
              aria-hidden="true"
            >
              {heroLeadBrand}
            </span>
            <span class="sr-only">{heroLeadPrefix}{heroLeadBrand}</span>
          </p>
          <p class="home-hero__summary">
            결제부터 상품권 매입, 마케팅과 솔루션 개발까지<br />
            굿데일리와 함께하세요!
          </p>
          <div class="home-hero__actions" aria-label="상담 및 서비스 이동">
            <a class="common-button common-button--primary" href={CONTACT.phoneHref} aria-label="전화 상담">
              전화 상담 <ArrowIcon />
            </a>
            <a class="common-button common-button--glass" href={CONTACT.kakaoChannel} target="_blank" rel="noopener" aria-label="카카오톡 문의">
              카카오톡 문의 <ArrowIcon />
            </a>
          </div>
          <div class="home-hero-platforms" aria-hidden="true">
            <ul class="home-hero-platforms__track">
              {[...partnerLogoChips, ...partnerLogoChips, ...partnerLogoChips].map((logo) => (
                <li class="partner-logo-chip">
                    <img src={logo.src} alt={logo.name} loading="lazy" data-partner={logo.name} />
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="home-hero__visual" aria-hidden="true">
          <span class="home-hero__orbit"></span>
          <span class="home-hero__bubble home-hero__bubble--large"></span>
          <span class="home-hero__bubble home-hero__bubble--small"></span>
          <span class="home-hero__cube"></span>
          <span class="home-hero__ring"></span>
        </div>
      </div>

      <!-- ② 관련 브랜드 워드마크 -->
      <div class="home-affiliates" aria-label="굿데일리 관련 브랜드">
        <div class="container home-affiliates__inner" data-affiliate-marks>
          {affiliateMarks.map((mark) => (
            <a class="home-affiliate-mark" href={mark.href}>
              {mark.icon === 'marketing' && (
                <svg class="home-affiliate-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4.5 16.5h15" />
                  <path d="M6.5 14l4-4 3 3 4.5-5" />
                  <path d="M15 8h3.5v3.5" />
                </svg>
              )}
              {mark.icon === 'pay' && (
                <svg class="home-affiliate-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="7" y="4.8" width="10" height="12.4" rx="2.4" />
                  <path d="M9.5 8h5" />
                  <path d="M9.5 11h5" />
                  <path d="M8.8 19.2h6.4" />
                  <path d="M12 17.2v2" />
                </svg>
              )}
              {mark.icon === 'voucher' && (
                <svg class="home-affiliate-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 8.5A2.5 2.5 0 0 1 7.5 6h9A2.5 2.5 0 0 1 19 8.5v1a2.5 2.5 0 0 0 0 5v1a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 5 15.5v-1a2.5 2.5 0 0 0 0-5v-1Z" />
                  <path d="M9 12h6" />
                  <path d="M12 9v6" />
                </svg>
              )}
              {mark.icon === 'solution' && (
                <svg class="home-affiliate-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="5" y="5" width="6" height="6" rx="2" />
                  <rect x="13" y="13" width="6" height="6" rx="2" />
                  <path d="M13.5 7.5H17a2 2 0 0 1 2 2V11" />
                  <path d="M10.5 16.5H7a2 2 0 0 1-2-2V13" />
                </svg>
              )}
              {mark.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <script>
      const affiliateMarks = Array.from(document.querySelectorAll('[data-affiliate-marks] .home-affiliate-mark'));
      const canAnimateAffiliateMarks = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (affiliateMarks.length && canAnimateAffiliateMarks) {
        let activeAffiliateIndex = 0;

        const activateAffiliateMark = () => {
          affiliateMarks.forEach((item, index) => {
            item.classList.toggle('home-affiliate-mark--active', index === activeAffiliateIndex);
          });
          activeAffiliateIndex = (activeAffiliateIndex + 1) % affiliateMarks.length;

          window.setTimeout(() => {
            affiliateMarks.forEach((item) => item.classList.remove('home-affiliate-mark--active'));
            window.setTimeout(activateAffiliateMark, 1000);
          }, 1100);
        };

        activateAffiliateMark();
      }

      const hero = document.querySelector('.home-hero');
      const canUseHeroTrail =
        hero &&
        window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (canUseHeroTrail) {
        const canvas = document.createElement('canvas');
        canvas.className = 'home-hero__cursor-canvas';
        canvas.setAttribute('aria-hidden', 'true');
        document.body.appendChild(canvas);

        const context = canvas.getContext('2d');
        const butterflies = Array.from(hero.querySelectorAll('.home-hero-butterfly'));
        const butterflyStates = butterflies.map((item, index) => ({
          item,
          angle: index * Math.PI + .35,
          radius: index ? 28 : 24,
          speed: index ? -.058 : .072,
          x: null,
          y: null,
          returnFromX: 0,
          returnFromY: 0,
          returnToX: 0,
          returnToY: 0,
          returnProgress: 0,
          releaseTimer: 0,
          mode: 'free',
        }));
        const points = [];
        let bounds = hero.getBoundingClientRect();
        let canvasWidth = window.innerWidth;
        let canvasHeight = window.innerHeight;
        let animationFrame = 0;
        let butterflyFrame = 0;
        let pointerPoint = null;
        let lastPoint = null;
        let isDrawing = false;

        const resizeCanvas = () => {
          bounds = hero.getBoundingClientRect();
          const ratio = window.devicePixelRatio || 1;
          canvasWidth = window.innerWidth;
          canvasHeight = window.innerHeight;
          canvas.width = Math.max(1, Math.floor(canvasWidth * ratio));
          canvas.height = Math.max(1, Math.floor(canvasHeight * ratio));
          canvas.style.width = `${canvasWidth}px`;
          canvas.style.height = `${canvasHeight}px`;
          context.setTransform(ratio, 0, 0, ratio, 0, 0);
        };

        const drawTrail = () => {
          context.clearRect(0, 0, canvasWidth, canvasHeight);
          const now = performance.now();

          for (let index = points.length - 1; index >= 0; index -= 1) {
            if (now - points[index].time > 850) points.splice(index, 1);
          }

          if (points.length > 1) {
            context.save();
            context.lineCap = 'round';
            context.lineJoin = 'round';

            for (let index = 1; index < points.length; index += 1) {
              const previous = points[index - 1];
              const current = points[index];
              const age = now - current.time;
              const ageAlpha = Math.max(0, 1 - age / 850);
              const tailProgress = index / (points.length - 1);
              const tailAlpha = Math.pow(tailProgress, .42);
              const alpha = Math.min(1, Math.pow(ageAlpha, .35) * tailAlpha * 1.18);
              const glowColor = '255, 255, 255';
              const coreColor = glowColor;

              context.beginPath();
              context.moveTo(previous.x, previous.y);
              context.lineTo(current.x, current.y);
              context.strokeStyle = `rgba(${glowColor}, ${alpha * .68})`;
              context.lineWidth = 3;
              context.shadowColor = `rgba(${glowColor}, ${alpha * .62})`;
              context.shadowBlur = 12;
              context.stroke();

              context.beginPath();
              context.moveTo(previous.x, previous.y);
              context.lineTo(current.x, current.y);
              context.strokeStyle = `rgba(${coreColor}, ${alpha})`;
              context.lineWidth = 1;
              context.shadowBlur = 0;
              context.stroke();
            }

            context.restore();
          }

          if (points.length) {
            animationFrame = window.requestAnimationFrame(drawTrail);
          } else {
            animationFrame = 0;
          }
        };

        const releaseButterfly = (state) => {
          if (state.mode !== 'chasing') return;
          const isWhite = state.item.classList.contains('home-hero-butterfly--white');
          state.mode = 'returning';
          state.returnFromX = state.x ?? 0;
          state.returnFromY = state.y ?? 0;
          state.returnToX = isWhite ? -42 : bounds.width + 38;
          state.returnToY = isWhite ? Math.min(bounds.height - 90, 520) : 150;
          state.returnProgress = 0;
          window.clearTimeout(state.releaseTimer);
          state.item.classList.add('home-hero-butterfly--returning');
        };

        const resetButterfly = (state) => {
          state.mode = 'free';
          state.x = null;
          state.y = null;
          state.item.classList.remove('home-hero-butterfly--orbiting', 'home-hero-butterfly--returning');
          state.item.style.removeProperty('transform');
          state.item.style.removeProperty('filter');
        };

        const moveButterflies = () => {
          bounds = hero.getBoundingClientRect();
          const isPointerInsideHero =
            pointerPoint &&
            pointerPoint.x >= bounds.left &&
            pointerPoint.x <= bounds.right &&
            pointerPoint.y >= bounds.top &&
            pointerPoint.y <= bounds.bottom;

          let shouldKeepRunning = Boolean(isPointerInsideHero);

          butterflyStates.forEach((state) => {
            const rect = state.item.getBoundingClientRect();
            const butterflyX = rect.left + rect.width / 2;
            const butterflyY = rect.top + rect.height / 2;
            const distance = isPointerInsideHero ? Math.hypot(pointerPoint.x - butterflyX, pointerPoint.y - butterflyY) : Infinity;
            const isWhite = state.item.classList.contains('home-hero-butterfly--white');
            const scaleY = isWhite ? -1 : 1;

            if (state.mode === 'returning') {
              state.returnProgress = Math.min(1, state.returnProgress + .024);
              const ease = 1 - Math.pow(1 - state.returnProgress, 3);
              const wobble = Math.sin(state.returnProgress * Math.PI * 5) * 18 * (1 - ease);
              const x = state.returnFromX + (state.returnToX - state.returnFromX) * ease;
              const y = state.returnFromY + (state.returnToY - state.returnFromY) * ease + wobble;
              const tilt = (isWhite ? 190 : 14) + Math.sin(state.returnProgress * Math.PI * 4) * 14;

              state.item.style.transform = `translate3d(${x}px, ${y}px, 0) rotate(${tilt}deg) scale(1, ${scaleY})`;
              state.item.style.filter = 'blur(0)';
              shouldKeepRunning = true;

              if (state.returnProgress >= 1) resetButterfly(state);
              return;
            }

            if (state.mode === 'free' && distance > 100) return;
            if (state.mode === 'chasing' && (!isPointerInsideHero || distance > 190)) {
              releaseButterfly(state);
              shouldKeepRunning = true;
              return;
            }

            if (state.mode === 'free') {
              window.clearTimeout(state.releaseTimer);
              state.x = rect.left - bounds.left;
              state.y = rect.top - bounds.top;
              state.mode = 'chasing';
              state.item.classList.remove('home-hero-butterfly--returning');
              state.item.classList.add('home-hero-butterfly--orbiting');
            }

            state.angle += state.speed;

            const targetX = pointerPoint.x - bounds.left - rect.width / 2 + Math.cos(state.angle) * state.radius * .42;
            const targetY = pointerPoint.y - bounds.top - rect.height / 2 + Math.sin(state.angle) * (state.radius * .32);
            const follow = isWhite ? .34 : .38;
            const tilt = Math.sin(state.angle) * 16;

            state.x += (targetX - state.x) * follow;
            state.y += (targetY - state.y) * follow;

            state.item.style.transform = `translate3d(${state.x}px, ${state.y}px, 0) rotate(${tilt}deg) scale(1, ${scaleY})`;
            state.item.style.filter = 'blur(0)';
            shouldKeepRunning = true;
          });

          if (shouldKeepRunning) {
            butterflyFrame = window.requestAnimationFrame(moveButterflies);
          } else {
            butterflyFrame = 0;
          }
        };

        const requestButterflyFrame = () => {
          if (!butterflyFrame && butterflyStates.length) {
            butterflyFrame = window.requestAnimationFrame(moveButterflies);
          }
        };

        window.addEventListener('pointerdown', (event) => {
          if (event.button !== 0) return;
          isDrawing = true;
        });

        window.addEventListener('pointerup', () => {
          isDrawing = false;
          lastPoint = null;
        });

        window.addEventListener('pointercancel', () => {
          isDrawing = false;
          lastPoint = null;
        });

        window.addEventListener('pointermove', (event) => {
          bounds = hero.getBoundingClientRect();
          const isInsideHero =
            event.clientX >= bounds.left &&
            event.clientX <= bounds.right &&
            event.clientY >= bounds.top &&
            event.clientY <= bounds.bottom;

          if (!isInsideHero) {
            lastPoint = null;
            pointerPoint = null;
            requestButterflyFrame();
            return;
          }

          pointerPoint = { x: event.clientX, y: event.clientY };
          requestButterflyFrame();

          const point = {
            x: event.clientX,
            y: event.clientY,
            time: performance.now(),
            isDrawing,
          };

          if (lastPoint && Math.hypot(point.x - lastPoint.x, point.y - lastPoint.y) < 2) {
            return;
          }

          points.push(point);
          if (points.length > 168) points.shift();
          lastPoint = point;

          if (!animationFrame) animationFrame = window.requestAnimationFrame(drawTrail);
        });

        window.addEventListener('blur', () => {
          isDrawing = false;
          lastPoint = null;
          pointerPoint = null;
          requestButterflyFrame();
        });

        resizeCanvas();
        window.addEventListener('resize', resizeCanvas, { passive: true });
        window.addEventListener('pointerup', () => {
          isDrawing = false;
        });
      }

      const initHomeReveal = () => {
        const revealTargets = Array.from(document.querySelectorAll([
          '.page-home .home-services .common-section-header',
          '.page-home .home-service-list > li',
          '.page-home .home-service-note',
          '.page-home .home-service-flow__lead',
          '.page-home .home-service-flow__subcopy',
          '.page-home .home-service-flow__step',
          '.page-home .home-service-flow__summary',
          '.page-home .home-about__media',
          '.page-home .home-about__content',
          '.page-home .home-partners .common-section-header',
          '.page-home .home-support__header',
          '.page-home .home-support-card',
        ].join(',')));
        const partnerCards = Array.from(document.querySelectorAll('.page-home .home-partner-card'));
        const partnerShowcase = document.querySelector('.page-home .home-partner-showcase');
        const canReveal = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        revealTargets.forEach((item, index) => {
          item.classList.add('home-reveal');
          item.style.setProperty('--reveal-delay', `${Math.min(index % 6, 5) * 70}ms`);
        });

        document.querySelector('.page-home .home-services .common-section-header')?.style.setProperty('--reveal-delay', '0ms');
        Array.from(document.querySelectorAll('.page-home .home-service-list > li')).forEach((item, index) => {
          item.style.setProperty('--reveal-delay', `${120 + index * 90}ms`);
        });

        document.querySelector('.page-home .home-service-flow__lead')?.style.setProperty('--reveal-delay', '0ms');
        document.querySelector('.page-home .home-service-flow__subcopy')?.style.setProperty('--reveal-delay', '80ms');
        Array.from(document.querySelectorAll('.page-home .home-service-flow__step')).forEach((item, index) => {
          item.style.setProperty('--reveal-delay', `${160 + index * 90}ms`);
        });
        document.querySelector('.page-home .home-service-flow__summary')?.style.setProperty('--reveal-delay', '540ms');

        partnerCards.forEach((item) => {
          item.classList.add('home-partner-card--reveal');
          item.style.setProperty('--partner-reveal-delay', `${Math.floor(Math.random() * 920)}ms`);
        });

        if (revealTargets.length && canReveal) {
          const revealObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('home-reveal--visible');
              observer.unobserve(entry.target);
            });
          }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });

          revealTargets.forEach((item) => revealObserver.observe(item));
        } else {
          revealTargets.forEach((item) => item.classList.add('home-reveal--visible'));
        }

        const revealPartnerCards = () => {
          partnerCards.forEach((item) => item.classList.add('home-partner-card--visible'));
        };

        if (partnerCards.length && partnerShowcase && canReveal) {
          const partnerObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              revealPartnerCards();
              observer.unobserve(entry.target);
            });
          }, { threshold: 0.2, rootMargin: '0px 0px -6% 0px' });

          partnerObserver.observe(partnerShowcase);
        } else {
          revealPartnerCards();
        }
      };

      if (document.readyState === 'loading') {
        window.addEventListener('DOMContentLoaded', initHomeReveal, { once: true });
      } else {
        initHomeReveal();
      }
    </script>

