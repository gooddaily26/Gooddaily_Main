      <path d="M40 40h7V24h-7Z" />
    </>
  )}

  {normalizedType === 'rate' && (
    <>
      <path d="M14 46h36" />
      <path d="M18 40h7V30h-7Z" />
      <path d="M29 40h7V20h-7Z" />
      <path d="M40 40h7V25h-7Z" />
    </>
  )}

  {normalizedType === 'shield' && (
    <>
      <path d="M32 12 50 19v12c0 12-8 19-18 23-10-4-18-11-18-23V19l18-7Z" />
      <path d="m24 32 6 6 11-13" />
    </>
  )}

  {normalizedType === 'bulk' && (
    <>
      <path d="M16 18h32a5 5 0 0 1 5 5v16a5 5 0 0 1-5 5H31l-10 7v-7h-5a5 5 0 0 1-5-5V23a5 5 0 0 1 5-5Z" />
    </>
  )}

  {normalizedType === 'automation' && (
    <>
      <path d="M18 33l9 9 19-22" />
    </>
  )}

  {normalizedType === 'settlement' && (
    <>
      <text x="32" y="37" fill="currentColor" stroke="none" text-anchor="middle" font-size="15" font-weight="700" font-family="Arial, sans-serif">AUTO</text>
    </>
  )}

  {normalizedType === 'dashboard' && (
    <>
      <rect x="12" y="14" width="40" height="36" rx="6" />
      <path d="M12 25h40" />
    </>
  )}

  {normalizedType === 'api' && (
    <>
      <circle cx="32" cy="32" r="8" />
      <path d="M32 12v7" />
      <path d="M32 45v7" />
      <path d="M12 32h7" />
      <path d="M45 32h7" />
      <path d="m18 18 5 5" />
      <path d="m41 41 5 5" />
      <path d="m46 18-5 5" />
      <path d="m23 41-5 5" />
    </>
