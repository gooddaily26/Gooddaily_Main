---
interface Props {
  type?: string;
  size?: 'small' | 'large';
}

const { type = 'feature', size = 'large' } = Astro.props;
const symbolTypes = [
  'marketing',
  'terminal',
  'voucher',
  'solution',
  'feature',
  'search',
  'naver',
  'ads',
  'google',
  'video',
  'youtube',
  'analytics',
  'payment',
  'gift',
  'qr',
  'sales',
  'rate',
  'shield',
  'bulk',
  'automation',
  'settlement',
  'dashboard',
  'api',
];
const normalizedType = symbolTypes.includes(type) ? type : 'feature';
---

<svg
  class={`service-symbol service-symbol--${normalizedType} service-symbol--${size}`}
  viewBox="0 0 64 64"
  aria-hidden="true"
  focusable="false"
>
  {normalizedType === 'marketing' && (
    <>
      <path d="M14 42h8l18-18 10 10" />
      <path d="M42 24h10v10" />
      <path d="M14 50h36" />
      <path d="M16 36h6" />
      <path d="M28 30h6" />
    </>
  )}

  {normalizedType === 'terminal' && (
    <>
      <rect x="18" y="12" width="28" height="40" rx="6" />
      <path d="M24 22h16" />
      <path d="M24 32h16" />
      <path d="M26 42h4" />
      <path d="M34 42h4" />
    </>
  )}

  {normalizedType === 'voucher' && (
    <>
      <path d="M12 24a6 6 0 0 0 0 12v6a4 4 0 0 0 4 4h32a4 4 0 0 0 4-4v-6a6 6 0 0 0 0-12v-6a4 4 0 0 0-4-4H16a4 4 0 0 0-4 4Z" />
    </>
  )}

  {normalizedType === 'solution' && (
    <>
      <rect x="14" y="16" width="36" height="28" rx="6" />
      <path d="M22 52h20" />
      <path d="M32 44v8" />
      <path d="M24 30h6l4-5 6 9h5" />
    </>
  )}

  {normalizedType === 'feature' && (
    <>
      <path d="M18 33l9 9 19-22" />
      <path d="M32 10a22 22 0 1 0 22 22" />
    </>
  )}

  {normalizedType === 'search' && (
    <>
      <circle cx="28" cy="28" r="13" />
      <path d="m38 38 10 10" />
      <path d="M22 28h12" />
      <path d="M28 22v12" />
    </>
  )}

  {normalizedType === 'naver' && (
    <>
      <rect x="16" y="16" width="32" height="32" rx="7" />
      <text x="32" y="39" fill="currentColor" stroke="none" text-anchor="middle" font-size="22" font-weight="700" font-family="Arial, sans-serif">N</text>
    </>
  )}

  {normalizedType === 'ads' && (
    <>
      <path d="M16 39V25l26-10v34L16 39Z" />
      <path d="M42 22h6v20h-6" />
      <path d="M19 39l4 10h8l-5-8" />
    </>
  )}

  {normalizedType === 'google' && (
    <>
      <rect x="16" y="16" width="32" height="32" rx="7" />
      <text x="32" y="39" fill="currentColor" stroke="none" text-anchor="middle" font-size="22" font-weight="700" font-family="Arial, sans-serif">G</text>
    </>
  )}

  {normalizedType === 'video' && (
    <>
      <rect x="13" y="18" width="30" height="28" rx="5" />
      <path d="m26 27 10 5-10 5V27Z" />
      <path d="m43 27 8-5v20l-8-5" />
    </>
  )}

  {normalizedType === 'youtube' && (
    <>
      <rect x="16" y="16" width="32" height="32" rx="7" />
      <text x="32" y="39" fill="currentColor" stroke="none" text-anchor="middle" font-size="22" font-weight="700" font-family="Arial, sans-serif">Y</text>
    </>
  )}

  {normalizedType === 'analytics' && (
    <>
      <path d="M14 48h36" />
      <path d="M20 42V29" />
      <path d="M32 42V18" />
      <path d="M44 42V24" />
    </>
  )}

  {normalizedType === 'payment' && (
    <>
      <rect x="12" y="18" width="40" height="28" rx="5" />
      <path d="M12 27h40" />
      <path d="M20 38h10" />
      <path d="M39 37l3 3 6-7" />
    </>
  )}

  {normalizedType === 'gift' && (
    <>
      <rect x="14" y="30" width="36" height="20" rx="5" />
      <rect x="11" y="20" width="42" height="9" rx="5" />
      <path d="M32 20v9" />
      <path d="M32 30v20" />
      <path d="M19 20c-2-5 1-9 6-8 5 1 7 8 7 8" />
      <path d="M45 20c2-5-1-9-6-8-5 1-7 8-7 8" />
    </>
  )}

  {normalizedType === 'qr' && (
    <>
      <path d="M14 14h14v14H14Z" />
